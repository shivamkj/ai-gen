{
  "name": "ai-gen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "format": "prettier . --write --list-different --cache --cache-strategy metadata",
    "preview": "./ai-gen",
    "clean": "rm -rf ai-gen dist/",
    "dev": "vite"
  },
  "dependencies": {
    "marked": "^15.0.12",
    "preact": "^10.26.4",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "prettier": "^3.7.4",
    "vite": "^6.4.1"
  },
  "prettier": {
    "$schema": "http://json.schemastore.org/prettierrc",
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "bracketSameLine": true
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
