<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gen-ai</string>

    <key>ProgramArguments</key>
    <array>
        <string>/path/to/gen-ai/gen-ai</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/path/to/gen-ai</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/gen-ai.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/gen-ai.error.log</string>
</dict>
</plist>
